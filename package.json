{
  "name": "rn-neo",
  "version": "0.4.0",
  "description": "Power of Neobrutalism, at palm of React Native",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "react-native": "lib/module/index",
  "types": "lib/typescript/module/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./app.plugin": "./app.plugin.js",
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "plugin/build/index.js",
    "app.plugin.js"
  ],
  "scripts": {
    "example": "yarn workspace rn-neo-example",
    "clean": "del-cli lib",
    "prepare": "bob build && yarn build:plugin",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "build:plugin": "tsc --project plugin/tsconfig.json",
    "prepublishOnly": "yarn prepare"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "neobrutalism",
    "ui",
    "ui-library",
    "design-system",
    "animation",
    "reanimated",
    "components",
    "theme"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gs-rumana/rn-neo.git"
  },
  "author": "gs-rumana <gursahb7@gmail.com> (https://github.com/gs-rumana)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gs-rumana/rn-neo/issues"
  },
  "homepage": "https://github.com/gs-rumana/rn-neo#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@expo/config-plugins": "^55.0.8",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@types/node": "^25.6.1",
    "@types/react": "^19.2.0",
    "@types/xcode": "^3.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "hermes-eslint": "^0.36.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.41.0",
    "react-native-reanimated": "^4.3.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2",
    "xcode": "^3.0.1"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=4.2.0",
    "react-native-worklets": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint"
    ],
    "version": "0.62.0"
  }
}
