---
interface Props {
  title: string;
  icon?: string;
  image?: string;
  imageAlt?: string;
  class?: string;
}

const { title, icon, image, imageAlt = "", class: className } = Astro.props;
---

<div class:list={[
  "card bg-base-200 border-4 border-neutral brutal-shadow brutal-shadow-hover group transition-all duration-300 hover:bg-base-100x",
  className
]}>
  {image && (
    <figure class="border-b-4 border-neutral bg-secondary/20 relative overflow-hidden h-48">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 group-hover:rotate-2"
      />
      <div class="absolute inset-0 bg-secondary/20 mix-blend-multiply group-hover:bg-transparent transition-colors"></div>
    </figure>
  )}

  <div class="card-body p-5">
    <div class="flex items-center gap-3">
      {icon && (
        <div class="w-12 h-12 bg-primary border-2 border-neutral flex items-center justify-center brutal-shadow-sm shrink-0">
          <i class:list={[icon, "text-2xl text-neutral"]}></i>
        </div>
      )}
      <h2 class="card-title text-2xl font-bold uppercase leading-tight transition-colors">
        <span class="relative transition-colors">
          {title}
          <!--<span class="absolute -bottom-1 left-0 w-0 h-1 bg-secondary group-hover:w-full transition-all duration-300"></span>-->
        </span>
      </h2>
    </div>

    <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-500 ease-in-out">
      <div class="overflow-hidden">
        <div class="pt-4 mt-4 border-t-2 border-neutral opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
          <slot />
        </div>
      </div>
    </div>

    <!--<div class="card-actions justify-end mt-2 group-hover:hidden transition-all">-->
    <!--   <span class="text-xs font-bold uppercase opacity-50 flex items-center gap-1">-->
    <!--     Hover to expand <i class="ri-arrow-down-line"></i>-->
    <!--   </span>-->
    <!--</div>-->
  </div>
</div>

<style>
  .card {
    /* Ensure the card doesn't jump too much when expanding if placed in a flex/grid container */
    align-self: start;
  }
</style>
