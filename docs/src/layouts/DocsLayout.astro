---
import Sidebar from '../components/docs/Sidebar.astro';
import '../styles/global.css';
import Search from '../components/docs/Search.astro';

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title} - RN Neo</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL('/rn-neo-cover.png', Astro.url)}
    />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta
      property="twitter:image"
      content={new URL('/rn-neo-cover.png', Astro.url)}
    />
  </head>
  <body class="prose prose-neutral max-w-none">
    <div class="drawer lg:drawer-open">
      <input id="docs-drawer" type="checkbox" class="drawer-toggle" />

      <!-- Page content -->
      <div class="drawer-content flex flex-col min-h-screen">
        <!-- Navbar -->
        <div
          class="navbar bg-base-100 border-b-2 border-black sticky top-0 z-30"
        >
          <div class="navbar-start">
            <!-- Hamburger — only visible on mobile -->
            <label for="docs-drawer" class="btn btn-ghost btn-square lg:hidden">
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
              >
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
              </svg>
            </label>
            <a href="/" class="font-black text-lg tracking-tight ml-2">RN Neo</a
            >
          </div>
          <div class="navbar-end gap-2">
            <a
              href="https://github.com/gs-rumana/rn-neo"
              class="btn btn-ghost btn-sm font-bold">GitHub</a
            >
            <!--<a href="/docs/getting-started" class="btn btn-neutral btn-sm font-black">Docs</a>-->
          </div>
        </div>

        <!-- Main content -->
        <main class="flex-1 px-6 py-10 w-full mx-auto">
          <div
            data-pagefind-body
            class="max-w-none lg:max-w-9/12 mx-auto prose-headings:font-black prose-code:rounded-none"
          >
            <slot />
          </div>
        </main>
      </div>

      <!-- Sidebar -->
      <div class="drawer-side z-40">
        <label
          for="docs-drawer"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <aside
          class="bg-base-100 border-r-2 border-black w-64 min-h-full px-4 py-4"
        >
          <div class="font-black text-lg px-2 py-2">Docs</div>
          <Search />
          <Sidebar currentPath={currentPath} />
        </aside>
      </div>
    </div>

    <!-- Modal -->
    <dialog id="search-modal" class="modal">
      <div class="modal-box max-w-2xl w-full mt-16">
        <div id="pagefind-search"></div>
      </div>
      <form method="dialog" class="modal-backdrop backdrop-blur">
        <button>close</button>
      </form>
    </dialog>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>

    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        new PagefindUI({
          element: '#pagefind-search',
          showSubResults: true,
          showImages: false,
          resetStyles: true,
        });

        const modal = document.getElementById('search-modal');

        // Focus input when modal opens
        modal.addEventListener('toggle', () => {
          if (modal.open) {
            setTimeout(() => {
              modal.querySelector('input')?.focus();
            }, 50);
          }
        });

        // ⌘K / Ctrl+K shortcut
        window.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            modal.open ? modal.close() : modal.showModal();
          }
          // Close on Escape (dialog handles this natively, but just in case)
          if (e.key === 'Escape') modal.close();
        });

        // Close modal when a result link is clicked
        modal.addEventListener('click', (e) => {
          if (e.target.closest('a')) modal.close();
        });
      });
    </script>

    <style>
      /* Override Pagefind UI to match Neo Brutalism */
      #pagefind-search {
        --pagefind-ui-scale: 0.8;
        --pagefind-ui-primary: var(--color-primary);
        --pagefind-ui-text: var(--color-base-content);
        --pagefind-ui-background: var(--color-base-100);
        --pagefind-ui-border: var(--color-base-300);
        --pagefind-ui-border-width: var(--border);
        --pagefind-ui-border-radius: var(--radius-field);
        --pagefind-ui-font: inherit;
      }

      /* Input field */
      #pagefind-search .pagefind-ui__search-input {
        border: 2px solid black !important;
        border-radius: 0 !important;
        box-shadow: none;
        font-weight: 600;
      }

      #pagefind-search .pagefind-ui__search-input:focus {
        outline: none;
        box-shadow: 3px 3px 0 black;
      }

      /* Results */
      #pagefind-search .pagefind-ui__result {
        border: 2px solid black;
        margin-bottom: 0.5rem;
        //padding: 0.75rem;
        box-shadow: 3px 3px 0 black;
      }

      #pagefind-search .pagefind-ui__result-link {
        font-weight: 800;
        color: black;
        text-decoration: none;
      }

      #pagefind-search .pagefind-ui__result-link:hover {
        text-decoration: underline;
      }

      /* Search button */
      #pagefind-search .pagefind-ui__search-clear {
        border-radius: 0 !important;
      }
    </style>
  </body>
</html>
